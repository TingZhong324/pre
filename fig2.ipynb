    "import sympy as sp\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.optimize import minimize\n",
    "from scipy.optimize import fsolve\n",
    "from scipy.signal import savgol_filter\n",
    "import matplotlib.ticker as ticker\n",
    "import scienceplots\n",
    "from sympy import symbols, Piecewise, log, And, Gt, Le\n",
    "plt.style.use(['nature','no-latex',\"grid\"])\n",
    "history = []\n",
    "EQ = [0, 0, 0, 0]  \n",
    "def newFF(I):\n",
    "    V0 = 1.5e-9  \n",
    "    rho = 1e3  \n",
    "    g = 9.8  \n",
    "    r = 2.75e-4  \n",
    "    d = 2e-4  \n",
    "    R = 8.314  \n",
    "    T = 298.15  \n",
    "    gamma_1 = 7.197e-2  \n",
    "    n0 = 1400  \n",
    "    mu0 = np.pi * 4e-7  \n",
    "    m0 = 2.7e-7  \n",
    "    m=8e-4\n",
    "    P0=1.013e5\n",
    "    a = 2.8e-3  \n",
    "    D = 3.7e-3  \n",
    "    H = 1e-3  \n",
    "    R0 = (3 * V0 / (4 * np.pi)) ** (1 / 3)\n",
    "    theta0 = np.pi - np.arcsin(r / R0)\n",
    "    Pl=gamma_1*2/R0+P0\n",
    "    n=(np.pi*r**2*H-np.pi*r**3*(2+3*np.cos(theta0)-np.cos(theta0)**3)/(3*np.sin(theta0)**3))/0.0245\n",
    "    h0=0.0001486\n",
    "    a1,h,theta,beta,= sp.symbols('a1,h,theta,beta,')  \n",
    "    def f(theta, h, beta, a1):\n",
    "        term1=-m0*g*(h+d*sp.cos(beta))\n",
    "        term2=gamma_1*((2*sp.pi*r**2)/(1+sp.cos(theta))+sp.pi*(r+d*sp.sin(beta))*sp.sqrt((r-d*sp.sin(beta))**2+h**2))\n",
    "        term3=-(n0*mu0*I*a**2*m)/(2*((D-h-d*sp.cos(beta))**2+a**2)**(3/2)) \n",
    "        term4_1=sp.pi*r**2*H-sp.pi*h*(r**2+(d*sp.sin(beta))**2+r*d*sp.sin(beta))/3-sp.pi*d**3*(2+3*sp.cos(beta)-sp.cos(beta)**3)/3\n",
    "        term4_2=sp.pi*r**2*H-sp.pi*r**3*(2+3*sp.cos(theta0)-sp.cos(theta0)**3)/(3*sp.sin(theta0)**3)\n",
    "        term4_3=-Pl*(sp.pi*h*(r**2+(d*sp.sin(beta))**2+r*d*sp.sin(beta))/3+sp.pi*d**3*(2+3*sp.cos(beta)-sp.cos(beta)**3)/3-sp.pi*r**3*(2+3*sp.cos(theta0)-sp.cos(theta0)**3)/(3*sp.sin(theta0)**3))\n",
    "        term4=-n*R*T*sp.log(term4_1/term4_2)+term4_3 \n",
    "        term5=(a1*((V0-sp.pi*r**3*(2-3*sp.cos(theta)+sp.cos(theta)**3)/(3*sp.sin(theta)**3)-sp.pi*h*(r**2+(d*sp.sin(beta))**2+r*d*sp.sin(beta))/3+sp.pi*d**3*(2-3*sp.cos(beta)+sp.cos(beta)**3)/3)))\n",
    "        return term1 + term2 + term3  + term4+term5\n",
    "    FFFF=f(theta, h, beta, a1)\n",
    "    d1 = FFFF.diff(theta)\n",
    "    d2 = FFFF.diff(h)\n",
    "    d3 = FFFF.diff(beta)\n",
    "    d4 = FFFF.diff(a1)\n",
    "    f1 = sp.lambdify([theta, h, beta,a1], d1, 'numpy')\n",
    "    f2 = sp.lambdify([theta, h, beta,a1], d2, 'numpy')\n",
    "    f3 = sp.lambdify([theta, h, beta,a1], d3, 'numpy')\n",
    "    f4 = sp.lambdify([theta, h, beta,a1], d4, 'numpy')\n",
    "    def z1(arg):\n",
    "        dtheta = arg[0]  \n",
    "        dh = arg[1] * 1e-4\n",
    "        dbeta = arg[2] \n",
    "        da=arg[3]\n",
    "        return f1(dtheta, dh, dbeta,da)\n",
    "    def z2(arg):\n",
    "        dtheta = arg[0] \n",
    "        dh = arg[1] * 1e-4\n",
    "        dbeta = arg[2] \n",
    "        da=arg[3]\n",
    "        return f2(dtheta, dh, dbeta,da)\n",
    "    def z3(arg):\n",
    "        dtheta = arg[0] \n",
    "        dh = arg[1] * 1e-4\n",
    "        dbeta = arg[2] \n",
    "        da=arg[3]\n",
    "        return f3(dtheta, dh, dbeta,da)\n",
    "    def z4(arg):\n",
    "        dtheta = arg[0]  \n",
    "        dh = arg[1] * 1e-4\n",
    "        dbeta = arg[2]\n",
    "        da=arg[3] \n",
    "        return f4(dtheta, dh, dbeta,da)\n",
    "    def eqs(arg):\n",
    "        EQ[0]=(z1(arg))\n",
    "        EQ[1]=(z2(arg))\n",
    "        EQ[2]=(z3(arg))\n",
    "        EQ[3]=(z4(arg))\n",
    "        return EQ\n",
    "    R0 = (3 * V0 / (4 * np.pi)) ** (1 / 3)\n",
    "    theta0 = np.pi - np.arcsin(r / R0)\n",
    "    arg = np.zeros(4)\n",
    "    arg[0] = (np.pi-np.arcsin(r/R0))\n",
    "    arg[1] = h0*1e4\n",
    "    arg[2] = np.pi*13/17\n",
    "    arg[3] = 1e8\n",
    "    if len(ARG)>1:\n",
    "        arg=ARG[-1]\n",
    "    result=fsolve(eqs,arg)\n",
    "    return result\n",
    "def rayleigh_analysis(I_vals, ARG, V0=1.5e-9, r=2.75e-4, d=2e-4, gamma=7.197e-2):\n",
    "    rho = 1000  \n",
    "    results = {\n",
    "        'I': I_vals,\n",
    "        'theta': [],\n",
    "        'h': [],\n",
    "        'beta': [],\n",
    "        'V_column': [],\n",
    "        'L_column': [],\n",
    "        'R_neck_est': [],\n",
    "        'lambda_critical': [],\n",
    "        'condition1': [],\n",
    "        'condition2': [],\n",
    "        'growth_rate': [],\n",
    "        'required_time': [],\n",
    "        'is_unstable': []\n",
    "    }\n",
    "    for i, (I_val, arg_vals) in enumerate(zip(I_vals, ARG)):\n",
    "        theta_val = arg_vals[0] % (2 * np.pi)\n",
    "        h_val = arg_vals[1] * 1e-4  \n",
    "        beta_val = arg_vals[2] % (2 * np.pi)\n",
    "        V_column = np.pi * h_val * (r**2 + (d*np.sin(beta_val))**2 + r*d*np.sin(beta_val)) / 3    \n",
    "        L_column = h_val\n",
    "        if L_column > 0 and V_column > 0:\n",
    "            R_neck = np.sqrt(V_column / (np.pi * L_column))\n",
    "        else:\n",
    "            R_neck = r\n",
    "        lambda_critical = 2 * np.pi * R_neck\n",
    "        lambda_max = 9.016 * R_neck\n",
    "        condition1 = L_column > lambda_critical\n",
    "        growth_rate_factor = 0.34\n",
    "        growth_rate = growth_rate_factor * np.sqrt(gamma / (rho * R_neck**3))\n",
    "        if i > 0:\n",
    "            dI_dt = abs(I_vals[i] - I_vals[i-1]) / 0.1\n",
    "            if dI_dt > 0:\n",
    "                t_stretch = 0.1\n",
    "            else:\n",
    "                t_stretch = 0.1\n",
    "        else:\n",
    "            t_stretch = 0.1\n",
    "        if growth_rate > 0:\n",
    "            required_time = 1.0 / growth_rate\n",
    "        else:\n",
    "            required_time = float('inf')\n",
    "        condition2 = required_time < t_stretch\n",
    "        is_unstable = condition1\n",
    "        results['theta'].append(theta_val)\n",
    "        results['h'].append(h_val)\n",
    "        results['beta'].append(beta_val)\n",
    "        results['V_column'].append(V_column)\n",
    "        results['L_column'].append(L_column)\n",
    "        results['R_neck_est'].append(R_neck)\n",
    "        results['lambda_critical'].append(lambda_critical)\n",
    "        results['condition1'].append(condition1)\n",
    "        results['condition2'].append(condition2)\n",
    "        results['growth_rate'].append(growth_rate)\n",
    "        results['required_time'].append(required_time)\n",
    "        results['is_unstable'].append(is_unstable)\n",
    "    for key in results:\n",
    "        if key != 'I':\n",
    "            results[key] = np.array(results[key])\n",
    "    return results\n",
    "ARG = []\n",
    "M = []\n",
    "b = 0.75\n",
    "a = 0\n",
    "dx = 1e-2\n",
    "for I_val in np.linspace(a, b, int((b - a) / dx)):\n",
    "    M.append(I_val)\n",
    "    ARG.append(newFF(I_val).tolist())  \n",
    "ARG = np.array(ARG)\n",
    "I = np.array(M)   \n",
    "stability_results = rayleigh_analysis(I, ARG)\n",
    "V0 = 1.5e-9\n",
    "r = 2.75e-4\n",
    "d = 2e-4\n",
    "R = 8.314\n",
    "T = 298.15\n",
    "n0 = 1400\n",
    "mu0 = np.pi * 4e-7\n",
    "m = 8e-4\n",
    "H = 1e-3\n",
    "R0 = (3 * V0 / (4 * np.pi)) ** (1 / 3)\n",
    "theta0 = np.pi - np.arcsin(r / R0)\n",
    "n = (np.pi * r**2 * H - np.pi * r**3 * (2 + 3 * np.cos(theta0) - np.cos(theta0)**3) / (3 * np.sin(theta0)**3)) / 0.0245  \n",
    "I00 = n * R * T * R0 / (n0 * mu0 * m)\n",
    "beta1 = 1.57\n",
    "threshold = (H - d - d * np.cos(beta1)) / R0\n",
    "x = I / I00\n",
    "y1 = ARG[:, 0] % (2 * np.pi)\n",
    "y2 = ARG[:, 1] / (R0 * 1e4)\n",
    "y3 = ARG[:, 2] % (2 * np.pi)\n",
    "def g1(k1):\n",
    "    idx = np.argmin(np.abs(x - k1))  \n",
    "    b1=ARG[:, 0]%(2*np.pi)\n",
    "    b2=ARG[:, 1]/(R0*1e4)\n",
    "    b3=ARG[:, 2]%(2*np.pi)\n",
    "    theta_val = b1[idx]  \n",
    "    h_val = b2[idx]  \n",
    "    beta_val = b3[idx]   \n",
    "    return h_val\n",
    "fig, axs = plt.subplots(3, 1, figsize=(4, 11))\n",
    "plt.subplots_adjust(hspace=0.3)\n",
    "plt.rc('xtick', labelsize=18)\n",
    "plt.rc('ytick', labelsize=18)\n",
    "for ax in axs:\n",
    "    for spine in ax.spines.values():\n",
    "        spine.set_linewidth(1.2)\n",
    "unstable_indices = np.where(stability_results['is_unstable'])[0]\n",
    "axs[0].plot(x, y2, color='orange', linewidth=1.6, linestyle='-')\n",
    "axs[0].scatter(30, g1(30), color='red', s=20, zorder=5)\n",
    "axs[0].axhline(y=threshold, color='red', linewidth=1.6, linestyle='--', label='Bottoming')   \n",
    "if len(unstable_indices) > 0:\n",
    "    axs[0].fill_between(x, 0, 5.1, where=stability_results['is_unstable'],\n",
    "                        color='red', alpha=0.2, label='Rayleigh Unstable')  \n",
    "axs[0].set_xlabel('$I/I_0$', fontsize=18)\n",#fig2(a)
    "axs[0].set_ylabel('$h/R_0$', fontsize=18)\n",
    "axs[0].set_title('(a)', loc='left', fontsize=17)\n",
    "axs[0].legend(loc='upper left', fontsize=13)\n",
